# Apify API token — used to fetch LinkedIn posts
APIFY_TOKEN=

# Comment generation runs through the `claude` CLI (Claude Code subscription),
# not the Anthropic API. These are optional overrides.
# CLAUDE_CLI=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_TIMEOUT_S=120

# Automatic daily fetch. Disabled by default — use the "Run Now" button on the
# Handles page to fetch on demand. Set to 1 to enable the scheduled run.
FETCH_SCHEDULE_ENABLED=0
# Daily fetch schedule (24h clock, local time); only used when enabled above
FETCH_SCHEDULE_HOUR=6
FETCH_SCHEDULE_MINUTE=0

# SQLite database file path
DATABASE_PATH=./li_comments.db

# Logging / crash diagnostics
LOG_LEVEL=INFO          # DEBUG for verbose troubleshooting
LOG_DIR=./logs          # app.log (rotated) + faulthandler.log written here
