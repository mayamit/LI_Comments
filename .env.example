# Apify API token — used to fetch LinkedIn posts
APIFY_TOKEN=

# Name shown in the app header ("LinkedIn Comment Generator for <name>")
OWNER_NAME=Amit Gandhi

# Comment generation runs through the `claude` CLI (Claude Code subscription),
# not the Anthropic API. These are optional overrides.
# CLAUDE_CLI=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_TIMEOUT_S=120
# Max concurrent `claude` CLI processes. Firing all tones at once makes the
# CLIs race on the shared login token, so some exit with "Not logged in".
# CLAUDE_MAX_CONCURRENCY=3
# Retries on transient CLI failures (e.g. the login-token race above).
# CLAUDE_MAX_RETRIES=2

# Automatic daily fetch. Disabled by default — use the "Run Now" button on the
# Handles page to fetch on demand. Set to 1 to enable the scheduled run.
FETCH_SCHEDULE_ENABLED=0
# Daily fetch schedule (24h clock, local time); only used when enabled above
FETCH_SCHEDULE_HOUR=6
FETCH_SCHEDULE_MINUTE=0

# Trending post discovery (the /discover view). Finds the highest-engagement
# posts on these topics within DISCOVERY_WINDOW, ranks them, and runs them
# through the comment pipeline. DISCOVERY_QUERIES seeds the editable topic list
# on first run (comma-separated). Use the "Run discovery now" button on demand.
DISCOVERY_QUERIES=AI agents,platform engineering
DISCOVERY_WINDOW=week          # any | 1h | 24h | week | month | 3months | 6months | year
DISCOVERY_MAX_POSTS_PER_QUERY=25
DISCOVERY_KEEP_TOP_N=10
# Optional scheduled daily discovery (off by default; topics are managed in the UI).
DISCOVERY_SCHEDULE_ENABLED=0
DISCOVERY_SCHEDULE_HOUR=7
DISCOVERY_SCHEDULE_MINUTE=0

# SQLite database file path
DATABASE_PATH=./li_comments.db

# Logging / crash diagnostics
LOG_LEVEL=INFO          # DEBUG for verbose troubleshooting
LOG_DIR=./logs          # app.log (rotated) + faulthandler.log written here
